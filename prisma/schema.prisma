// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Platform user (visitor or admin)
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  passwordHash  String
  role          String        @default("VISITOR") // "VISITOR" | "ADMIN"
  createdAt     DateTime      @default(now())
  sessions      QuizSession[]
  posts         Post[]
  comments      Comment[]
  likes         Like[]
}

// Source document uploaded by the user
model Document {
  id        String          @id @default(cuid())
  fileName  String
  title     String
  category  String
  createdAt DateTime        @default(now())
  banks     QuestionBank[]
}

// A bank of questions grouped by topic
model QuestionBank {
  id          String     @id @default(cuid())
  title       String
  description String
  category    String
  subcategory String     @default("")
  icon        String     @default("BookOpen")
  color       String     @default("emerald")
  level       String     @default("TOUS")
  documentId  String?
  document    Document?  @relation(fields: [documentId], references: [id])
  questions   Question[]
  createdAt   DateTime   @default(now())
}

// A single QCM question
model Question {
  id             String        @id @default(cuid())
  bankId         String
  bank           QuestionBank  @relation(fields: [bankId], references: [id], onDelete: Cascade)
  order          Int           @default(0)
  question       String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctAnswer  String // "A" | "B" | "C" | "D"
  correctAnswer2 String? // optional 2nd correct answer
  explanation    String
  level          String        @default("TOUS")
  createdAt      DateTime      @default(now())
  examQuestions  ExamQuestion[]
}

// A structured exam (e.g. 50 questions)
model Exam {
  id            String         @id @default(cuid())
  title         String
  description   String
  durationMin   Int            @default(60)
  examQuestions ExamQuestion[]
  createdAt     DateTime       @default(now())
}

// Junction table exam <-> question with ordering
model ExamQuestion {
  id         String   @id @default(cuid())
  examId     String
  questionId String
  order      Int
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// A user's quiz/exam attempt
model QuizSession {
  id             String          @id @default(cuid())
  title          String
  mode           String // "immediate" | "final"
  sourceType     String // "bank" | "exam"
  sourceId       String
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  score          Int             @default(0)
  totalQuestions Int
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  answers        SessionAnswer[]
}

// A user's answer to a single question in a session (snapshot stored)
model SessionAnswer {
  id             String      @id @default(cuid())
  sessionId      String
  questionId     String
  questionText   String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctAnswer  String
  correctAnswer2 String?
  userAnswer     String?
  userAnswer2    String?
  explanation    String
  isCorrect      Boolean?
  answeredAt     DateTime?
  session        QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// === Social Network ===
model Post {
  id          String    @id @default(cuid())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  type        String    @default("discussion")
  tags        String    @default("")
  likesCount  Int       @default(0)
  comments    Comment[]
  likes       Like[]
  createdAt   DateTime  @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

// === Email notifications log ===
model EmailLog {
  id        String   @id @default(cuid())
  toEmail   String
  subject   String
  body      String
  type      String   @default("info")
  sentAt    DateTime @default(now())
  status    String   @default("pending")
}
