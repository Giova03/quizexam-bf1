// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Platform user (visitor or admin)
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  passwordHash  String
  role          String        @default("VISITOR") // "VISITOR" | "ADMIN"
  // Auto-generated 8-char alphanumeric referral code (unique per user).
  // Backfill default uses md5(random()) so existing rows get a value during migration.
  referralCode  String        @unique @default(dbgenerated("(upper(substr(md5(random()::text || clock_timestamp()::text), 1, 8)))"))
  // The referral code of the user who invited this user (null if no referral).
  referredBy    String?
  // Public profile fields (added in P6).
  bio           String?
  establishment String?
  // JSON-encoded email preferences (added in F4):
  // { dailyReminder, replyNotifications, challengeReminders }. Stored as a
  // string column rather than a typed Json field so older Prisma clients and
  // the existing migration path keep working without a schema rewrite.
  emailPreferences String    @default("{}")
  // Subscription tier (added in F5): "free" | "premium" | "admin".
  // Free users are rate-limited to FREE_DAILY_LIMIT questions/day, cannot
  // upload PDFs, cannot use the AI tutor, and cannot download certificates.
  // Premium users get unlimited questions + all features. Admin bypasses.
  subscription String        @default("free")
  createdAt     DateTime      @default(now())
  sessions      QuizSession[]
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  forumTopics   ForumTopic[]
  forumReplies  ForumReply[]
  reports       Report[]
  // Social/community features (added in F6):
  studyGroupsCreated  StudyGroup[]        @relation("StudyGroupCreator")
  studyGroupMembers   StudyGroupMember[]  @relation("StudyGroupMember")
  eventsCreated       Event[]             @relation("EventCreator")
  articles            Article[]           @relation("ArticleAuthor")
}

// Source document uploaded by the user
model Document {
  id        String          @id @default(cuid())
  fileName  String
  title     String
  category  String
  createdAt DateTime        @default(now())
  banks     QuestionBank[]
}

// A bank of questions grouped by topic
model QuestionBank {
  id          String     @id @default(cuid())
  title       String
  description String
  category    String
  subcategory String     @default("")
  icon        String     @default("BookOpen")
  color       String     @default("emerald")
  level       String     @default("TOUS")
  documentId  String?
  document    Document?  @relation(fields: [documentId], references: [id])
  questions   Question[]
  forumTopics ForumTopic[]
  createdAt   DateTime   @default(now())
}

// A single QCM question
model Question {
  id             String        @id @default(cuid())
  bankId         String
  bank           QuestionBank  @relation(fields: [bankId], references: [id], onDelete: Cascade)
  order          Int           @default(0)
  question       String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctAnswer  String // "A" | "B" | "C" | "D"
  correctAnswer2 String? // optional 2nd correct answer
  explanation    String
  level          String        @default("TOUS")
  difficulty     String        @default("medium") // "easy" | "medium" | "hard"
  // Optional media attached to the question (added in F4):
  // - imageUrl points to /uploads/<file>.png|jpg|webp|gif
  // - audioUrl points to /uploads/<file>.mp3|wav|ogg
  // Both are surfaced in the session-view (image above, audio below) and in
  // the results-view detailed review.
  imageUrl       String?
  audioUrl       String?
  createdAt      DateTime      @default(now())
  examQuestions  ExamQuestion[]
}

// A structured exam (e.g. 50 questions)
model Exam {
  id            String         @id @default(cuid())
  title         String
  description   String
  durationMin   Int            @default(60)
  examQuestions ExamQuestion[]
  createdAt     DateTime       @default(now())
}

// Junction table exam <-> question with ordering
model ExamQuestion {
  id         String   @id @default(cuid())
  examId     String
  questionId String
  order      Int
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// A user's quiz/exam attempt
model QuizSession {
  id             String          @id @default(cuid())
  title          String
  mode           String // "immediate" | "final"
  sourceType     String // "bank" | "exam"
  sourceId       String
  userId         String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  score          Int             @default(0)
  totalQuestions Int
  startedAt      DateTime        @default(now())
  completedAt    DateTime?
  answers        SessionAnswer[]
}

// A user's answer to a single question in a session (snapshot stored)
model SessionAnswer {
  id             String      @id @default(cuid())
  sessionId      String
  questionId     String
  questionText   String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  correctAnswer  String
  correctAnswer2 String?
  userAnswer     String?
  userAnswer2    String?
  explanation    String
  isCorrect      Boolean?
  answeredAt     DateTime?
  // Snapshot of the question's media at the time the session was started
  // (added in F4). Mirrors the Question.imageUrl / audioUrl columns so the
  // media keeps rendering even if the bank's question is later edited.
  imageUrl       String?
  audioUrl       String?
  session        QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// === Social Network ===
model Post {
  id          String    @id @default(cuid())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  type        String    @default("discussion")
  tags        String    @default("")
  likesCount  Int       @default(0)
  comments    Comment[]
  likes       Like[]
  createdAt   DateTime  @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([postId, userId])
}

// === Email notifications log ===
model EmailLog {
  id        String   @id @default(cuid())
  toEmail   String
  subject   String
  body      String
  type      String   @default("info")
  sentAt    DateTime @default(now())
  status    String   @default("pending")
}

// === Forum (par matière) ===
// Discussion topics organized by category / question bank.
model ForumTopic {
  id          String        @id @default(cuid())
  title       String
  content     String
  authorId    String
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  // Optional link to a QuestionBank so users can discuss a specific matière.
  bankId      String?
  bank        QuestionBank? @relation(fields: [bankId], references: [id], onDelete: SetNull)
  category    String        @default("general")
  replies     ForumReply[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())
}

// Reply to a forum topic. The topic author (or an admin) can mark a single
// reply as the "best answer" via /api/forum/topics/[id]/best-answer.
model ForumReply {
  id           String      @id @default(cuid())
  topicId      String
  topic        ForumTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  content      String
  authorId     String
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  isBestAnswer Boolean     @default(false)
  createdAt    DateTime    @default(now())
}

// === Study groups (par matière / concours) ===
// A user-created study group with a unique 6-char invite code.
// Creator is auto-added as a member when the group is created (see /api/groups POST).
// Any authenticated user can join via the invite code (no approval workflow).
model StudyGroup {
  id          String             @id @default(cuid())
  name        String
  description String             @default("")
  creatorId   String
  creator     User               @relation("StudyGroupCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  // 6-char uppercase alphanumeric invite code (unique). Generated server-side.
  inviteCode  String             @unique
  members     StudyGroupMember[]
  createdAt   DateTime           @default(now())
}

// Membership row. A user is a member of a group iff a row exists.
// Joined-at is recorded for display ("membre depuis X").
model StudyGroupMember {
  id        String     @id @default(cuid())
  groupId   String
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("StudyGroupMember", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime   @default(now())
  @@unique([groupId, userId])
}

// === Calendar events (examens / concours / échéances) ===
// Display-only — no real-time sync. Admins create events; everyone sees them.
// Users can "S'inscrire" — this just stores the eventId in localStorage on the client.
model Event {
  id         String   @id @default(cuid())
  title      String
  description String  @default("")
  // "exam" | "contest" | "deadline"
  type       String   @default("deadline")
  startDate  DateTime
  endDate    DateTime?
  createdBy  String
  creator    User     @relation("EventCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

// === Blog / Articles ===
// Admin or contributor-authored articles. Drafts (published=false) are only
// visible to their author (and admins) via the API; published articles are
// listed publicly on the Blog view.
model Article {
  id            String    @id @default(cuid())
  title         String
  content       String
  excerpt       String    @default("")
  authorId      String
  author        User      @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  category      String    @default("general")
  published     Boolean   @default(false)
  featuredImage String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// === Moderation reports ===
// Users can report content (forum topic, reply, post, comment, etc.).
// Admins review and resolve/dismiss reports via /api/reports.
model Report {
  id         String   @id @default(cuid())
  reporterId String?
  reporter   User?    @relation(fields: [reporterId], references: [id], onDelete: SetNull)
  // What was reported: e.g. "forum_topic", "forum_reply", "post", "comment", "user", "question"
  targetType String
  targetId   String
  reason     String
  status     String   @default("pending") // "pending" | "resolved" | "dismissed"
  createdAt  DateTime @default(now())
}
